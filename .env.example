# Copy to .env and fill in the values. .env is git-ignored.

# Domaines des services (sans protocole). Le protocole https:// est ajouté par docker-compose.
APP_HOST=app.localtest.me
KEYCLOAK_HOST=keycloak.localtest.me
VITE_HOST=vite.localtest.me

# Moteur de routage BRouter (exposé au client par Vite — préfixe VITE_).
# Laisser vide pour utiliser le serveur public https://brouter.de/brouter
# (gratuit, sans SLA ni quota garanti). Renseigner l'URL d'une instance
# auto-hébergée pour un usage intensif/production, ex. https://brouter.mondomaine.tld/brouter
VITE_BROUTER_URL=

# Postgres (app database)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Postgres (Keycloak database)
KEYCLOAK_DB_PASSWORD=keycloak

# Keycloak admin console bootstrap credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Shared secret for the "rails-app" OIDC client.
# Must match the value injected into Keycloak's realm import and the value
# Rails passes to OmniAuth. Generate with: openssl rand -base64 32
RAILS_KEYCLOAK_CLIENT_SECRET=

# Strava OAuth app credentials (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
