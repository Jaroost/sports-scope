# Copy to .env and fill in the values. .env is git-ignored.

# Domaines des services (sans protocole). Le protocole https:// est ajouté par docker-compose.
APP_HOST=app.localtest.me
KEYCLOAK_HOST=keycloak.localtest.me
VITE_HOST=vite.localtest.me

# Moteur de routage BRouter (exposé au client par Vite — préfixe VITE_).
# Laisser vide : l'app utilise alors l'instance auto-hébergée servie sous son
# propre domaine (/brouter, service `brouter` du docker-compose). Renseigner pour
# repointer ailleurs, ex. le serveur public https://brouter.de/brouter (gratuit,
# sans SLA ni quota garanti).
VITE_BROUTER_URL=

# Données BRouter — bbox des tuiles .rd5 à télécharger : lon_min,lat_min,lon_max,lat_max
# (grille de 5°). Défaut = Europe entière, 110 tuiles / ~3,4 Go.
# Un sous-ensemble Alpes suffirait par ex. avec -5,40,20,55 (~2,2 Go).
BROUTER_BBOX=-30,30,45,70
# Intervalle de resynchronisation, en secondes (défaut 7 jours — les tuiles sont
# régénérées environ une fois par semaine en amont).
BROUTER_SYNC_INTERVAL=604800
# Dimensionnement de la JVM du moteur.
BROUTER_XMX=1500m
BROUTER_THREADS=4

# Postgres (app database)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Postgres (Keycloak database)
KEYCLOAK_DB_PASSWORD=keycloak

# Keycloak admin console bootstrap credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Shared secret for the "rails-app" OIDC client.
# Must match the value injected into Keycloak's realm import and the value
# Rails passes to OmniAuth. Generate with: openssl rand -base64 32
RAILS_KEYCLOAK_CLIENT_SECRET=

# Strava OAuth app credentials (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
