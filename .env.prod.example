# Domaines des services (sans protocole).
APP_HOST=sports.logicraft.ch
KEYCLOAK_HOST=sports-keycloak.logicraft.ch

# Tag de l'image Rails à déployer (produit par bin/release).
# Utiliser un SHA git pour épingler une version précise, ex: a1b2c3d
IMAGE_TAG=latest

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Postgres (Keycloak database)
KEYCLOAK_DB_PASSWORD=

# Keycloak admin console bootstrap credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# Shared secret for the "rails-app" OIDC client.
# Generate with: openssl rand -base64 32
RAILS_KEYCLOAK_CLIENT_SECRET=

# Rails secret key base.
# Generate with: docker compose -f docker-compose.prod.yml run --rm rails bundle exec rails secret
SECRET_KEY_BASE=

# Strava OAuth app credentials (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
