<% content_for :title, t("strava.activity_summary") %>

<div class="mb-3">
  <%= link_to dashboard_path, class: "btn btn-link p-0 d-inline-flex align-items-center gap-1" do %>
    <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
    <span><%= t("strava.back_to_dashboard") %></span>
  <% end %>
</div>

<% if @source == "imported" %>
  <div data-vue-component="ActivityDetail" data-vue-props='<%= { activityId: @activity_id, source: "imported" }.to_json %>'></div>
<% elsif @strava_linked %>
  <div data-vue-component="ActivityDetail" data-vue-props='<%= { activityId: @activity_id, source: "strava" }.to_json %>'></div>
<% else %>
  <div class="alert alert-info d-flex align-items-center gap-2">
    <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
    <span><%= t("strava.not_linked") %></span>
    <%= link_to profile_path, class: "btn btn-warning ms-auto" do %>
      <i class="fa-brands fa-strava me-1" aria-hidden="true"></i><%= t("profile.strava.link") %>
    <% end %>
  </div>
<% end %>
