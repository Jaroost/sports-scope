<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t("app.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="i18n-locale" content="<%= I18n.locale %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% if ENV["THUNDERFOREST_API_KEY"].present? %>
      <meta name="thunderforest-api-key" content="<%= ENV["THUNDERFOREST_API_KEY"] %>">
    <% end %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= vite_client_tag %>
    <%= vite_stylesheet_tag 'application.scss' %>
    <%= vite_typescript_tag 'application' %>
  </head>

  <body class="<%= yield(:body_class) if content_for?(:body_class) %>">
    <% unless content_for?(:hide_navbar) %>
    <nav class="navbar navbar-expand-md navbar-dark bg-dark fixed-top shadow-sm">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand sports-scope-brand d-flex align-items-center gap-2" do %>
          <i class="fa-solid fa-mountain-sun text-warning" aria-hidden="true"></i>
          <span class="d-none d-md-inline"><%= t("app.title") %></span>
        <% end %>
        <%= yield :navbar_actions %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarContent">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <%= link_to root_path, class: "nav-link" do %>
                <i class="fa-solid fa-house me-1" aria-hidden="true"></i><%= t("nav.home") %>
              <% end %>
            </li>
            <% if user_signed_in? %>
              <li class="nav-item">
                <%= link_to dashboard_path, class: "nav-link" do %>
                  <i class="fa-solid fa-gauge-high me-1" aria-hidden="true"></i><%= t("nav.dashboard") %>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to routes_index_path, class: "nav-link" do %>
                  <i class="fa-solid fa-route me-1" aria-hidden="true"></i><%= t("nav.routes") %>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to profile_path, class: "nav-link" do %>
                  <i class="fa-solid fa-sliders me-1" aria-hidden="true"></i><%= t("nav.profile") %>
                <% end %>
              </li>
            <% end %>
          </ul>
          <ul class="navbar-nav align-items-center">
            <li class="nav-item">
              <%= link_to "EN", url_for(locale: :en), class: "nav-link #{'active fw-semibold' if I18n.locale == :en}" %>
            </li>
            <li class="nav-item">
              <%= link_to "FR", url_for(locale: :fr), class: "nav-link #{'active fw-semibold' if I18n.locale == :fr}" %>
            </li>
            <% if user_signed_in? %>
              <% unless current_user.strava_linked? %>
                <li class="nav-item">
                  <%= button_to "/auth/strava", method: :post, class: "btn btn-warning ms-2", data: { turbo: false } do %>
                    <i class="fa-brands fa-strava me-1" aria-hidden="true"></i><%= t("nav.link_strava") %>
                  <% end %>
                </li>
              <% end %>
              <li class="nav-item">
                <%= button_to logout_path, method: :delete, class: "btn btn-outline-light ms-2", data: { turbo: false } do %>
                  <i class="fa-solid fa-right-from-bracket me-1" aria-hidden="true"></i><%= t("nav.logout") %>
                <% end %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= button_to "/auth/keycloak", method: :post, class: "btn btn-primary ms-2", data: { turbo: false } do %>
                  <i class="fa-solid fa-right-to-bracket me-1" aria-hidden="true"></i><%= t("nav.login") %>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>
    <% end %>

    <main class="<%= content_for?(:container_class) ? yield(:container_class) : 'container' %>">
      <% if notice %>
        <div class="alert alert-success d-flex align-items-center gap-2">
          <i class="fa-solid fa-circle-check" aria-hidden="true"></i><span><%= notice %></span>
        </div>
      <% end %>
      <% if alert %>
        <div class="alert alert-warning d-flex align-items-center gap-2">
          <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i><span><%= alert %></span>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
