<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t("app.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="i18n-locale" content="<%= I18n.locale %>">
    <% if user_signed_in? %>
      <meta name="user-preferences" content="<%= current_user.preferences_with_defaults.to_json %>">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% if ENV["THUNDERFOREST_API_KEY"].present? %>
      <meta name="thunderforest-api-key" content="<%= ENV["THUNDERFOREST_API_KEY"] %>">
    <% end %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%# PWA — rend le site installable (Android / Play Store via TWA) %>
    <link rel="manifest" href="/manifest.webmanifest">
    <meta name="theme-color" content="#212529">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Sports Scope">
    <link rel="apple-touch-icon" href="/icon-192.png">

    <%= vite_client_tag %>
    <%= vite_stylesheet_tag 'application.scss' %>
    <%= vite_typescript_tag 'application' %>
  </head>

  <body class="<%= yield(:body_class) if content_for?(:body_class) %>">
    <% unless content_for?(:hide_navbar) %>
    <nav class="navbar navbar-expand-md navbar-dark bg-dark fixed-top shadow-sm">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand sports-scope-brand d-flex align-items-center gap-2" do %>
          <i class="fa-solid fa-mountain-sun text-warning" aria-hidden="true"></i>
          <span class="d-none d-md-inline"><%= t("app.title") %></span>
        <% end %>
        <%= yield :navbar_actions %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarContent">
          <ul class="navbar-nav me-auto">
            <% if user_signed_in? %>
              <%# Menus configurables depuis le profil : ordre et visibilité (cf. NavbarHelper). %>
              <% navbar_menu_items(current_user).each do |item| %>
                <li class="nav-item">
                  <% if item[:key] == "new_route" %>
                    <%# Ouvre la modale nom + type avant d'aller au créateur (même îlot que la home). %>
                    <span data-vue-component="NewRouteButton" data-vue-props='<%= { variant: "nav" }.to_json %>'></span>
                  <% else %>
                    <%= link_to item[:path], class: "nav-link" do %>
                      <i class="fa-solid <%= item[:icon] %> me-1" aria-hidden="true"></i><span class="nav-label"><%= item[:label] %></span>
                    <% end %>
                  <% end %>
                </li>
              <% end %>
            <% end %>
          </ul>
          <ul class="navbar-nav ">
            <% if user_signed_in? %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="fa-solid fa-circle-user fa-lg" aria-hidden="true"></i>
                  <span class="nav-label"><%= current_user.display_name %></span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                  <li><h6 class="dropdown-header"><%= t("nav.language") %></h6></li>
                  <li>
                    <%= link_to url_for(locale: :en), class: "dropdown-item d-flex align-items-center justify-content-between #{'active' if I18n.locale == :en}" do %>
                      <span>English</span>
                      <% if I18n.locale == :en %><i class="fa-solid fa-check" aria-hidden="true"></i><% end %>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to url_for(locale: :fr), class: "dropdown-item d-flex align-items-center justify-content-between #{'active' if I18n.locale == :fr}" do %>
                      <span>Français</span>
                      <% if I18n.locale == :fr %><i class="fa-solid fa-check" aria-hidden="true"></i><% end %>
                    <% end %>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= link_to profile_path, class: "dropdown-item" do %>
                      <i class="fa-solid fa-sliders me-2" aria-hidden="true"></i><%= t("nav.profile") %>
                    <% end %>
                  </li>
                  <li>
                    <%= button_to logout_path, method: :delete, class: "dropdown-item", data: { turbo: false } do %>
                      <i class="fa-solid fa-right-from-bracket me-2" aria-hidden="true"></i><%= t("nav.logout") %>
                    <% end %>
                  </li>
                </ul>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "EN", url_for(locale: :en), class: "nav-link #{'active fw-semibold' if I18n.locale == :en}" %>
              </li>
              <li class="nav-item">
                <%= link_to "FR", url_for(locale: :fr), class: "nav-link #{'active fw-semibold' if I18n.locale == :fr}" %>
              </li>
              <li class="nav-item">
                <%= button_to "/auth/keycloak", method: :post, class: "btn btn-primary ms-2", data: { turbo: false } do %>
                  <i class="fa-solid fa-right-to-bracket me-1" aria-hidden="true"></i><%= t("nav.login") %>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>
    <% end %>

    <main class="<%= content_for?(:container_class) ? yield(:container_class) : 'container' %>">
      <% if notice %>
        <div class="alert alert-success d-flex align-items-center gap-2">
          <i class="fa-solid fa-circle-check" aria-hidden="true"></i><span><%= notice %></span>
        </div>
      <% end %>
      <% if alert %>
        <div class="alert alert-warning d-flex align-items-center gap-2">
          <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i><span><%= alert %></span>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <% if user_signed_in? %>
      <%# Boîte de dialogue « profil » accessible partout via [data-profile-trigger]. %>
      <div data-vue-component="ProfileDialog" data-vue-props='<%= {
            preferences: current_user.preferences_with_defaults,
            defaults: User::DEFAULT_PREFERENCES,
            stravaLinked: current_user.strava_linked?,
            canLinkStrava: can?(:link, :strava),
            unlinkPath: unlink_strava_path,
            deleteActivitiesPath: delete_strava_activities_path,
            hasStravaActivities: current_user.strava_activities.exists?
          }.to_json %>'></div>
    <% end %>

    <%# Bannière d'installation PWA (Android : invite native ; iOS : instructions). %>
    <div data-vue-component="PwaInstall"></div>
  </body>
</html>
