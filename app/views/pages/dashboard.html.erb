<% content_for :title, t("nav.dashboard") %>

<div class="d-flex align-items-center gap-3 mb-2">
  <span class="dashboard-badge bg-primary-subtle text-primary">
    <i class="fa-solid fa-gauge-high" aria-hidden="true"></i>
  </span>
  <h1 class="mb-0"><%= t("nav.dashboard") %></h1>
</div>
<p class="text-muted">
  <i class="fa-solid fa-user-astronaut me-1 text-muted" aria-hidden="true"></i><strong><%= current_user.display_name %></strong>
</p>

<%# Deux onglets — pastilles à la manière de la page « Mes itinéraires » (btn-group
    warning/outline). Onglet 1 : historique détaillé + activités récentes Strava
    (ou l'invitation à lier le compte). Onglet 2 : activités importées (.fit). %>
<div class="btn-group btn-group-sm mb-3 dashboard-tabs" role="tablist" aria-label="<%= t("nav.dashboard") %>">
  <button
    type="button"
    class="btn btn-outline-secondary dashboard-tab active d-flex align-items-center gap-1"
    data-bs-toggle="pill"
    data-bs-target="#dash-strava"
    role="tab"
    aria-controls="dash-strava"
    aria-selected="true"
  >
    <i class="fa-brands fa-strava" aria-hidden="true"></i>
    <span><%= t("dashboard.tab_strava") %></span>
  </button>
  <button
    type="button"
    class="btn btn-outline-secondary dashboard-tab d-flex align-items-center gap-1"
    data-bs-toggle="pill"
    data-bs-target="#dash-imported"
    role="tab"
    aria-controls="dash-imported"
    aria-selected="false"
  >
    <i class="fa-solid fa-file-import" aria-hidden="true"></i>
    <span><%= t("dashboard.tab_imported") %></span>
  </button>
</div>

<div class="tab-content">
  <div class="tab-pane fade show active" id="dash-strava" role="tabpanel">
    <% if current_user.strava_linked? %>
      <div data-vue-component="StravaBackfill" class="mb-3"></div>
      <div data-vue-component="HelloStrava"></div>
    <% else %>
      <div class="alert alert-info d-flex align-items-center gap-2">
        <i class="fa-brands fa-strava text-warning" aria-hidden="true"></i>
        <span><%= t("strava.not_linked") %></span>
        <%= link_to profile_path, class: "btn btn-warning ms-auto" do %>
          <i class="fa-brands fa-strava me-1" aria-hidden="true"></i><%= t("profile.strava.link") %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="tab-pane fade" id="dash-imported" role="tabpanel">
    <div data-vue-component="ImportFitActivity"></div>
  </div>
</div>
