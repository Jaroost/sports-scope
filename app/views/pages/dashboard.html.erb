<% content_for :title, t("nav.dashboard") %>

<div class="d-flex align-items-center gap-3 mb-2">
  <span class="dashboard-badge bg-primary-subtle text-primary">
    <i class="fa-solid fa-gauge-high" aria-hidden="true"></i>
  </span>
  <h1 class="mb-0"><%= t("nav.dashboard") %></h1>
</div>
<p class="text-muted">
  <i class="fa-solid fa-user-astronaut me-1 text-muted" aria-hidden="true"></i><strong><%= current_user.display_name %></strong>
</p>

<%# La section Strava n'apparaît que si le compte est lié ; sinon on invite à le
    lier depuis le profil. L'import .fit reste disponible dans tous les cas. %>
<% if current_user.strava_linked? %>
  <div data-vue-component="HelloStrava"></div>
<% else %>
  <div class="alert alert-info d-flex align-items-center gap-2">
    <i class="fa-brands fa-strava text-warning" aria-hidden="true"></i>
    <span><%= t("strava.not_linked") %></span>
    <%= link_to profile_path, class: "btn btn-warning ms-auto" do %>
      <i class="fa-brands fa-strava me-1" aria-hidden="true"></i><%= t("profile.strava.link") %>
    <% end %>
  </div>
<% end %>

<div data-vue-component="ChainWax" data-vue-props='{"compact":true}' class="mb-4"></div>

<div data-vue-component="ImportFitActivity"></div>
