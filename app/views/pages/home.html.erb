<% content_for :container_class, "container-fluid" %>

<div class="px-4 text-center home-hero">

  <h1 class="display-5 fw-bold"><%= t("app.title") %></h1>
  <div class="hero-icon mb-3 gap-1">
    <i class="fa-solid fa-route"></i>
    <i class="fa-solid fa-mountain"></i>
    <i class="fa-solid fa-person-hiking"></i>
    <i class="fa-solid fa-person-biking"></i>
  </div>

  <% if user_signed_in? %>
    <%# Bouton unique « Tout rafraîchir » : synchronise résumés + vélos + streams et
        notifie les widgets ci-dessous (via un événement window) de se recharger. %>
    <% if current_user.strava_linked? %>
      <div class="mb-4">
        <div data-vue-component="RefreshAll"></div>
      </div>
    <% end %>
    <%# Plan du jour : sortie objectif + « que faire aujourd'hui » (charge d'entraînement).
        Nécessite des activités (Strava ou .fit) ET l'interrupteur du profil (masquable). %>
    <% if (current_user.strava_linked? || current_user.imported_activities.exists?) &&
          current_user.preferences_with_defaults.dig("display", "show_performance_widget") %>
      <div class="row justify-content-center mb-4">
        <div class="col-lg-8">
          <div data-vue-component="TodayPlanWidget" data-vue-props='<%= { stravaLinked: current_user.strava_linked? }.to_json %>'></div>
        </div>
      </div>
    <% end %>
    <%# Sans Strava lié, les km des chaînes ne peuvent pas être rafraîchis : widget masqué.
        Avec Strava, il reste masquable depuis le profil (display.show_chain_widget). %>
    <% if current_user.strava_linked? && current_user.preferences_with_defaults.dig("display", "show_chain_widget") %>
      <div class="row justify-content-center mb-5">
        <div class="col-lg-8">
          <div data-vue-component="ChainWax" data-vue-props='<%= { compact: true, stravaLinked: current_user.strava_linked? }.to_json %>'></div>
        </div>
      </div>
    <% end %>
    <%# Boutons d'accueil : mêmes menus que la barre de navigation, mais pilotés par
        l'interrupteur « accueil » du profil (cf. NavbarHelper#home_menu_items), distinct
        de la visibilité dans la navbar. Le premier bouton ressort en « primary », sauf
        « créer un itinéraire » qui garde sa modale (îlot NewRouteButton). %>
    <p class="d-flex flex-wrap justify-content-center gap-2">
      <% home_menu_items(current_user).each_with_index do |item, i| %>
        <% if item[:key] == "new_route" %>
          <span data-vue-component="NewRouteButton"></span>
        <% else %>
          <%= link_to item[:path], class: "btn btn-lg home-button #{i.zero? ? 'btn-primary' : 'btn-outline-secondary'}" do %>
            <i class="fa-solid <%= item[:icon] %> me-2" aria-hidden="true"></i><%= item[:label] %>
          <% end %>
        <% end %>
      <% end %>
    </p>
  <% else %>

    <p class="lead text-muted"><%= t("pages.home_lead") %></p>
    <p>
      <%= button_to "/auth/keycloak", method: :post, class: "btn btn-primary btn-lg home-button", data: { turbo: false } do %>
        <i class="fa-solid fa-right-to-bracket me-2" aria-hidden="true"></i><%= t("nav.login") %>
      <% end %>
    </p>

    <div class="row g-3 mt-5 home-features text-start">
      <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body">
            <div class="feature-icon bg-warning-subtle text-warning mb-2">
              <i class="fa-solid fa-map-location-dot" aria-hidden="true"></i>
            </div>
            <h3 class="h6 fw-bold mb-1"><%= t("pages.feature_builder_title") %></h3>
            <p class="text-muted small mb-0"><%= t("pages.feature_builder_body") %></p>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body">
            <div class="feature-icon bg-warning-subtle text-warning mb-2">
              <i class="fa-solid fa-route" aria-hidden="true"></i>
            </div>
            <h3 class="h6 fw-bold mb-1"><%= t("pages.feature_routes_title") %></h3>
            <p class="text-muted small mb-0"><%= t("pages.feature_routes_body") %></p>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body">
            <div class="feature-icon bg-success-subtle text-success mb-2">
              <i class="fa-solid fa-chart-line" aria-hidden="true"></i>
            </div>
            <h3 class="h6 fw-bold mb-1"><%= t("pages.feature_charts_title") %></h3>
            <p class="text-muted small mb-0"><%= t("pages.feature_charts_body") %></p>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body">
            <div class="feature-icon bg-danger-subtle text-danger mb-2">
              <i class="fa-solid fa-heart-pulse" aria-hidden="true"></i>
            </div>
            <h3 class="h6 fw-bold mb-1"><%= t("pages.feature_stats_title") %></h3>
            <p class="text-muted small mb-0"><%= t("pages.feature_stats_body") %></p>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
