<div class="px-4 py-5 my-5 text-center home-hero">
  <div class="hero-icon mb-3 gap-1">
    <i class="fa-solid fa-route"></i>
    <i class="fa-solid fa-mountain"></i>
    <i class="fa-solid fa-person-hiking"></i>
    <i class="fa-solid fa-person-biking"></i>
  </div>
  <h1 class="display-5 fw-bold"><%= t("app.title") %></h1>
  <p class="lead text-muted"><%= t("pages.home_lead") %></p>

  <% if user_signed_in? %>
    <p class="d-flex flex-wrap justify-content-center gap-2">
      <%= link_to dashboard_path, class: "btn btn-primary btn-lg" do %>
        <i class="fa-solid fa-gauge-high me-2" aria-hidden="true"></i><%= t("nav.dashboard") %>
      <% end %>
      <%= link_to routes_index_path, class: "btn btn-outline-secondary btn-lg" do %>
        <i class="fa-solid fa-route me-2" aria-hidden="true"></i><%= t("pages.home_nav_routes") %>
      <% end %>
      <%= link_to new_route_path, class: "btn btn-warning btn-lg" do %>
        <i class="fa-solid fa-map-location-dot me-2" aria-hidden="true"></i><%= t("pages.feature_builder_cta") %>
      <% end %>
    </p>
  <% else %>
    <p>
      <%= button_to "/auth/keycloak", method: :post, class: "btn btn-primary btn-lg", data: { turbo: false } do %>
        <i class="fa-solid fa-right-to-bracket me-2" aria-hidden="true"></i><%= t("nav.login") %>
      <% end %>
    </p>
  <% end %>

  <div class="row g-3 mt-5 home-features text-start">
    <div class="col-md-6 col-lg-3">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <div class="feature-icon bg-warning-subtle text-warning mb-2">
            <i class="fa-solid fa-map-location-dot" aria-hidden="true"></i>
          </div>
          <h3 class="h6 fw-bold mb-1"><%= t("pages.feature_builder_title") %></h3>
          <p class="text-muted small mb-0"><%= t("pages.feature_builder_body") %></p>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-lg-3">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <div class="feature-icon bg-warning-subtle text-warning mb-2">
            <i class="fa-solid fa-route" aria-hidden="true"></i>
          </div>
          <h3 class="h6 fw-bold mb-1"><%= t("pages.feature_routes_title") %></h3>
          <p class="text-muted small mb-0"><%= t("pages.feature_routes_body") %></p>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-lg-3">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <div class="feature-icon bg-success-subtle text-success mb-2">
            <i class="fa-solid fa-chart-line" aria-hidden="true"></i>
          </div>
          <h3 class="h6 fw-bold mb-1"><%= t("pages.feature_charts_title") %></h3>
          <p class="text-muted small mb-0"><%= t("pages.feature_charts_body") %></p>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-lg-3">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <div class="feature-icon bg-danger-subtle text-danger mb-2">
            <i class="fa-solid fa-heart-pulse" aria-hidden="true"></i>
          </div>
          <h3 class="h6 fw-bold mb-1"><%= t("pages.feature_stats_title") %></h3>
          <p class="text-muted small mb-0"><%= t("pages.feature_stats_body") %></p>
        </div>
      </div>
    </div>
  </div>
</div>
