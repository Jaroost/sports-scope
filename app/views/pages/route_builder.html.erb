<% content_for :title, t("routes.builder_title") %>
<% content_for :container_class, "container-fluid route-builder-container" %>
<% content_for :navbar_actions do %>
  <div class="d-flex gap-1 d-md-none me-1 align-items-center">
    <%= link_to routes_index_path, class: "btn btn-sm btn-outline-light", title: t("routes.back"), aria: { label: t("routes.back") } do %>
      <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
    <% end %>
    <%# Boutons Image / GPX / Komoot téléportés ici par RouteBuilder.vue (états réactifs) %>
    <span id="rb-navbar-actions" class="d-flex gap-1"></span>
    <%= button_tag type: "button", class: "btn btn-sm btn-warning", id: "navbar-route-save-btn", title: t("routes.save"), aria: { label: t("routes.save") } do %>
      <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
    <% end %>
  </div>
<% end %>
<%
  # GPX partagé via le Web Share Target (filet de sécurité serveur, cf. PagesController#share_target) :
  # transmis en base64 — caractères [A-Za-z0-9+/=] sûrs dans l'attribut single-quote ci-dessous.
  rb_props = { routeId: @route_id }
  if @shared_gpx.present?
    rb_props[:sharedGpx] = Base64.strict_encode64(@shared_gpx)
    rb_props[:sharedGpxName] = @shared_gpx_name
  end
%>
<div data-vue-component="RouteBuilder" data-vue-props='<%= rb_props.to_json %>'></div>
