<% content_for :title, t("profile.title") %>

<div class="d-flex align-items-center gap-3 mb-2">
  <span class="dashboard-badge bg-primary-subtle text-primary">
    <i class="fa-solid fa-sliders" aria-hidden="true"></i>
  </span>
  <h1 class="mb-0"><%= t("profile.title") %></h1>
</div>
<p class="text-muted">
  <%= t("profile.lead") %> · <i class="fa-solid fa-user-astronaut me-1 text-muted" aria-hidden="true"></i><strong><%= current_user.display_name %></strong>
</p>

<section class="card mb-3 shadow-sm">
  <div class="card-header d-flex align-items-center gap-2">
    <i class="fa-brands fa-strava text-warning" aria-hidden="true"></i>
    <h2 class="h5 mb-0"><%= t("profile.strava.title") %></h2>
  </div>
  <div class="card-body">
    <% if current_user.strava_linked? %>
      <div class="d-flex align-items-center gap-3 flex-wrap">
        <span class="badge bg-success-subtle text-success d-inline-flex align-items-center gap-1 fs-6">
          <i class="fa-solid fa-circle-check" aria-hidden="true"></i><%= t("profile.strava.connected") %>
        </span>
        <%= button_to unlink_strava_path, method: :delete, class: "btn btn-outline-danger btn-sm ms-sm-auto",
              data: { turbo: false },
              form: { onsubmit: "return confirm('#{j(t('profile.strava.unlink_confirm'))}')" } do %>
          <i class="fa-solid fa-link-slash me-1" aria-hidden="true"></i><%= t("profile.strava.unlink") %>
        <% end %>
      </div>
      <% if current_user.strava_activities.exists? %>
        <hr class="my-3">
        <div class="d-flex align-items-center gap-3 flex-wrap">
          <p class="text-muted small mb-0"><%= t("profile.strava.delete_activities_help") %></p>
          <%= button_to delete_strava_activities_path, method: :delete, class: "btn btn-outline-danger btn-sm ms-sm-auto",
                data: { turbo: false },
                form: { onsubmit: "return confirm('#{j(t('profile.strava.delete_activities_confirm'))}')" } do %>
            <i class="fa-solid fa-trash me-1" aria-hidden="true"></i><%= t("profile.strava.delete_activities") %>
          <% end %>
        </div>
      <% end %>
    <% elsif can? :link, :strava %>
      <p class="text-muted small mb-3"><%= t("profile.strava.help") %></p>
      <%= button_to "/auth/strava", method: :post, class: "btn btn-warning", data: { turbo: false } do %>
        <i class="fa-brands fa-strava me-1" aria-hidden="true"></i><%= t("profile.strava.link") %>
      <% end %>
    <% else %>
      <p class="text-muted small mb-0"><%= t("profile.strava.not_allowed") %></p>
    <% end %>
  </div>
</section>

<div data-vue-component="UserProfile" data-vue-props='<%= { preferences: current_user.preferences_with_defaults, defaults: User::DEFAULT_PREFERENCES }.to_json %>'></div>
