<% content_for :title, t("profile.title") %>

<div class="d-flex align-items-center gap-3 mb-2">
  <span class="dashboard-badge bg-primary-subtle text-primary">
    <i class="fa-solid fa-sliders" aria-hidden="true"></i>
  </span>
  <h1 class="mb-0"><%= t("profile.title") %></h1>
</div>
<p class="text-muted">
  <%= t("profile.lead") %> · <i class="fa-solid fa-user-astronaut me-1 text-muted" aria-hidden="true"></i><strong><%= current_user.display_name %></strong>
</p>

<div data-vue-component="UserProfile" data-vue-props='<%= { preferences: current_user.preferences_with_defaults }.to_json %>'></div>
