#!/usr/bin/env bash
set -e

# Remove a potentially pre-existing server.pid for Rails.
rm -f /app/tmp/pids/server.pid

# Wait for the database to accept connections.
if [[ -n "${DATABASE_HOST}" ]]; then
  until pg_isready -h "${DATABASE_HOST}" -p "${DATABASE_PORT:-5432}" -U "${DATABASE_USER:-postgres}" >/dev/null 2>&1; do
    echo "Waiting for postgres at ${DATABASE_HOST}:${DATABASE_PORT:-5432}..."
    sleep 1
  done
fi

# Install gems if Gemfile.lock is newer than what's installed.
if [[ -f /app/Gemfile ]]; then
  bundle check >/dev/null 2>&1 || bundle install
fi

# Install JS deps if needed.
if [[ -f /app/package.json ]]; then
  if [[ ! -d /app/node_modules ]] || [[ /app/pnpm-lock.yaml -nt /app/node_modules ]]; then
    pnpm install --frozen-lockfile || pnpm install
  fi
fi

# Prepare the DB for the Rails service only.
if [[ "$1" == "bundle" && "$2" == "exec" && "$3" == "rails" ]]; then
  bundle exec rails db:prepare 2>/dev/null || true
fi

exec "$@"
