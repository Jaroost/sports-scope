#!/usr/bin/env bash
set -e

rm -f /app/tmp/pids/server.pid

if [[ -n "${EXTRA_CA_CERT}" && -f "${EXTRA_CA_CERT}" ]]; then
  cp "${EXTRA_CA_CERT}" /usr/local/share/ca-certificates/extra.crt
  update-ca-certificates >/dev/null
fi

if [[ -n "${DATABASE_HOST}" ]]; then
  until pg_isready -h "${DATABASE_HOST}" -p "${DATABASE_PORT:-5432}" -U "${DATABASE_USER:-postgres}" >/dev/null 2>&1; do
    echo "Waiting for postgres at ${DATABASE_HOST}:${DATABASE_PORT:-5432}..."
    sleep 1
  done
fi

if [[ -f /app/Gemfile ]]; then
  echo "Checking gems..."
  bundle check >/dev/null 2>&1 || bundle install
fi

if [[ "$1" == "bundle" && "$2" == "exec" && "$3" == "rails" ]]; then
  bundle exec rails db:prepare 2>/dev/null || true
fi

exec "$@"
