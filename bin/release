#!/usr/bin/env bash
set -e

# Par défaut réseau local via hostname du serveur.
# Surcharge avec: REGISTRY=registry.logicraft.ch bin/release
REGISTRY=${REGISTRY:-jaroost-server:5000}
IMAGE=$REGISTRY/sports-scope
GIT_SHA=$(git rev-parse --short HEAD)

docker logout $REGISTRY 2>/dev/null || true
docker login $REGISTRY

echo "Building $IMAGE:$GIT_SHA ..."
docker build -f Dockerfile.prod -t $IMAGE:$GIT_SHA -t $IMAGE:latest .

echo "Pushing to $REGISTRY ..."
docker push $IMAGE:$GIT_SHA
docker push $IMAGE:latest

echo "Done: $IMAGE:$GIT_SHA"
