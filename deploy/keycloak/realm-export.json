{
  "id": "sports-scope",
  "realm": "sports-scope",
  "displayName": "Sports Scope",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "rememberMe": true,
  "ssoSessionIdleTimeoutRememberMe": 2592000,
  "ssoSessionMaxLifespanRememberMe": 2592000,
  "defaultRoles": ["uma_authorization", "offline_access"],
  "requiredCredentials": ["password"],
  "passwordPolicy": "length(8)",
  "clients": [
    {
      "clientId": "rails-app",
      "name": "Sports Scope Rails App",
      "enabled": true,
      "publicClient": false,
      "secret": "${env.RAILS_KEYCLOAK_CLIENT_SECRET}",
      "redirectUris": [
        "${env.APP_HOST}/*"
      ],
      "webOrigins": [
        "${env.APP_HOST}"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "${env.APP_HOST}/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${env.GOOGLE_CLIENT_ID}",
        "clientSecret": "${env.GOOGLE_CLIENT_SECRET}",
        "syncMode": "IMPORT"
      }
    }
  ],
  "users": [
    {
      "username": "demo@sports-scope.local",
      "email": "demo@sports-scope.local",
      "firstName": "Demo",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "demopass",
          "temporary": false
        }
      ]
    }
  ]
}
